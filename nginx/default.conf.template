lua_package_path '/usr/local/openresty/nginx/lua/?.lua;;';

server {
    listen       ${SERVER_PORT};
    index  index.html;
    # 去掉 CONTEXT_PATH 前缀，例如 /main/xxx 变成 /xxx
    
    location ${CONTEXT_PATH}/lua/sign_code {
        # 处理 OPTIONS 请求
        if ($request_method = 'OPTIONS') {
            add_header Access-Control-Allow-Origin *;
            add_header Access-Control-Allow-Methods 'GET, POST, OPTIONS';
            add_header Access-Control-Allow-Headers 'Content-Type, Authorization';
            add_header Access-Control-Max-Age 1728000;
            return 204;
        }

        content_by_lua_file /usr/local/openresty/nginx/lua/sign_api.lua;
    }
    
    location ${CONTEXT_PATH}/echo {
        echo "Hello world!";
    }
    
    # 获取 IAM keyId 的接口
    location ${CONTEXT_PATH}/keys/iam-key-id {
        content_by_lua_block {
            local key_id_file = "/usr/local/openresty/nginx/lua/keys/iam-key-id.txt"
            
            local file = io.open(key_id_file, "r")
            if not file then
                ngx.status = 500
                ngx.header.content_type = "text/plain"
                ngx.say("IAM key ID file not found")
                ngx.exit(500)
            end
            
            local key_id = file:read("*all"):gsub("%s+$", "")
            file:close()
            
            ngx.header.content_type = "text/plain"
            ngx.say(key_id)
        }
    }
    
    # 获取 IAM 公钥的接口
    location ${CONTEXT_PATH}/keys/iam-public-key {
        content_by_lua_block {
            local public_key_file = "/usr/local/openresty/nginx/lua/keys/iam-public-key.pem"
            
            local file = io.open(public_key_file, "r")
            if not file then
                ngx.status = 500
                ngx.header.content_type = "text/plain"
                ngx.say("IAM public key file not found")
                ngx.exit(500)
            end
            
            local public_key = file:read("*all"):gsub("%s+$", "")
            file:close()
            
            ngx.header.content_type = "text/plain"
            ngx.say(public_key)
        }
    }
    
    location ^~ ${CONTEXT_PATH}/api/ {
        proxy_pass http://$GATEWAY_HOST:$GATEWAY_PORT/;
        proxy_set_header   Host    $host;
        proxy_set_header   X-Real-IP   $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
    }
    
    location ^~ ${CONTEXT_PATH}/auth/ {
        proxy_pass http://$IAM_HOST:$IAM_PORT/auth/;
        proxy_set_header   Host    $host;
        proxy_set_header   X-Real-IP   $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
    }
    
    location ^~ ${CONTEXT_PATH}/doc/ {
        proxy_pass http://$GATEWAY_HOST:$GATEWAY_PORT/;
        proxy_set_header   Host    $host;
        proxy_set_header   X-Real-IP   $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
    }
    
    location ~ \.(js|css)$ {
        rewrite ^${CONTEXT_PATH}(.*)$ /$1 break;
        expires 1h;
        root   /usr/local/openresty/nginx/html/;
    }
    
    # 主应用 SPA：CONTEXT_PATH 需与构建时 VITE_CONTEXT_PATH 一致；深链刷新回落 index.html
    location / {
        rewrite ^${CONTEXT_PATH}(.*)$ /$1 break;
        try_files $uri $uri/ /index.html;
        root   /usr/local/openresty/nginx/html/;
    }
    
    location ~ .*\.(gif|jpg|jpeg|png|bmp|swf)$ {
        rewrite ^${CONTEXT_PATH}(.*)$ /$1 break;
        expires 30d;
        root   /usr/local/openresty/nginx/html/;
    }
    
    location ~ .*\.(eot|ttf|woff)$  {
        add_header Access-Control-Allow-Origin *;
    }
    
    error_page  404    /404;
}
