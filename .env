# 与 Docker 构建 ARG `VITE_BUILD_MODE` 对应；本地 `vite dev` 使用 development
VITE_BUILD_MODE=development

VITE_APPLICATION_CODE=g2rain-main-shell
VITE_CONTEXT_PATH=/main
VITE_BACKEND_ORIGIN=https://43.138.13.145:443
VITE_TOKEN_END_POINT=/auth/token
VITE_AUTH_END_POINT=/auth/authorize
VITE_REDIRECT_URI=/sso_callback
VITE_SSO_BASE_URL=https://43.138.13.145:443
