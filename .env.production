# 与 `npx vite build --mode <mode>` 一致；镜像构建时 Dockerfile 会传 `VITE_BUILD_MODE`（默认 production）
VITE_BUILD_MODE=production

VITE_APPLICATION_CODE=g2rain-main-shell
VITE_CONTEXT_PATH=/main
VITE_TOKEN_END_POINT=/auth/token
VITE_SSO_BASE_URL=${SSO_BASE_URL}
VITE_AUTH_END_POINT=/auth/authorize
VITE_REDIRECT_URI=/sso_callback